# ── Streamlit Community Cloud Secrets ────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in your values.
# On Streamlit Cloud: Settings → Secrets — paste as TOML.
# NEVER commit secrets.toml to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL      = "https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY = "sb_publishable_..."   # public anon key (safe for browser)

# ── Free AI — Groq (Recommended) ─────────────────────────────────────────────
# https://console.groq.com — free tier: 14,400 req/day, ~200ms
GROQ_API_KEY = "gsk_..."

# ── Free AI — Google Gemini (Fallback) ───────────────────────────────────────
# https://aistudio.google.com — free tier: 1,500 req/day
GOOGLE_API_KEY = "AI..."

# ── INTL FastAPI Backend (Optional) ──────────────────────────────────────────
# URL to your deployed FastAPI instance (Railway, Fly.io, Render, etc.)
# If unset, the dashboard reads directly from Supabase.
INTL_API_URL = "https://your-api.railway.app"
