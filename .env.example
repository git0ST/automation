# Copy this to .env and fill in your keys. Never commit .env to git.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set to "local" to use Ollama, or "cloud" to use a cloud API
LLM_PROVIDER=local

# ── Local (Ollama) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini          # or llama3.2:3b, mistral:7b, etc.

# ── Cloud APIs ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...    # https://console.anthropic.com
OPENAI_API_KEY=sk-...           # https://platform.openai.com
GROQ_API_KEY=gsk_...            # https://console.groq.com  (free, fast)

# Default cloud model (used when LLM_PROVIDER=cloud)
CLOUD_MODEL=claude-sonnet-4-6   # or gpt-4o-mini, groq/llama-3.1-70b
CLOUD_PROVIDER=anthropic        # anthropic | openai | groq

# ── Free AI — Groq (Recommended for INTL) ─────────────────────────────────────
# https://console.groq.com — free tier: 14,400 req/day, ~200ms latency
# Models: llama-3.1-8b-instant (fast), llama-3.3-70b-versatile (smart)
# GROQ_API_KEY already listed above — this is a reminder it drives INTL AI

# ── Free AI — Google Gemini (Fallback) ────────────────────────────────────────
# https://aistudio.google.com — free tier: 1,500 req/day
GOOGLE_API_KEY=AI...            # Gemini Flash fallback when Groq unavailable

# ── Finnhub — Real-time market data + news (Recommended) ─────────────────────
# https://finnhub.io/register — free, 60 req/min, real-time US equities/forex/crypto
# Without this, dashboard uses yfinance (15-min delayed)
FINNHUB_API_KEY=...

# ── INTL FastAPI Backend ───────────────────────────────────────────────────────
# URL to your deployed FastAPI instance (Railway, Fly.io, Render, etc.)
# If unset, Streamlit dashboard reads directly from Supabase.
INTL_API_URL=http://localhost:8000   # or https://your-api.railway.app

# ── Supabase ───────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...  # public anon key (safe for Streamlit)
SUPABASE_SERVICE_KEY=sb_secret_...    # service key — server-side only, never commit

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_TOKEN=ntn_...            # notion.so/my-integrations → your integration secret
NOTION_PAGE_ID=...              # 32-char ID from the URL of the page you shared
