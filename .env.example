# Copy this to .env and fill in your keys. Never commit .env to git.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Set to "local" to use Ollama, or "cloud" to use a cloud API
LLM_PROVIDER=local

# ── Local (Ollama) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini          # or llama3.2:3b, mistral:7b, etc.

# ── Cloud APIs ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...    # https://console.anthropic.com
OPENAI_API_KEY=sk-...           # https://platform.openai.com
GROQ_API_KEY=gsk_...            # https://console.groq.com  (free, fast)

# Default cloud model (used when LLM_PROVIDER=cloud)
CLOUD_MODEL=claude-sonnet-4-6   # or gpt-4o-mini, groq/llama-3.1-70b
CLOUD_PROVIDER=anthropic        # anthropic | openai | groq

# ── Notion ────────────────────────────────────────────────────────────────────
NOTION_TOKEN=ntn_...            # notion.so/my-integrations → your integration secret
NOTION_PAGE_ID=...              # 32-char ID from the URL of the page you shared
